{
  "buildCommand": "pnpm --filter @workspace/al-bayaan run build",
  "outputDirectory": "artifacts/al-bayaan/dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://cadb33fb-b58f-4cec-8f02-9487c6d03663-00-cdt0iu5aw8qn.riker.replit.dev/api/:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
