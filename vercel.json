{
  "buildCommand": "pnpm --filter @workspace/al-bayaan run build",
  "outputDirectory": "artifacts/al-bayaan/dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://c1e065a4-def5-4705-b06e-35ca3c74c8ed-00-e6g06pgnnhkg.picard.replit.dev/api/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
