{
  "buildCommand": "pnpm --filter @workspace/al-bayaan run build",
  "outputDirectory": "artifacts/al-bayaan/dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://24f1bafb-6113-4e86-92bd-4c11679bca27-00-2i4za0ixsdu44.spock.replit.dev/api/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
